{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kurisu",
  "version": "1.0.0",
  "identifier": "com.catedesu.kurisu",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Kurisu",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "theme": "Dark",
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: https://*.anilist.co https://anilist.co; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
